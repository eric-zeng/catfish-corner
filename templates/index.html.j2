<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Catfish Corner</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Comic+Neue:ital,wght@0,300;0,400;0,700;1,300;1,400;1,700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="style.css">
  <script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
</head>
<body>
  <h1>🐟 bront and friends' catfish corner 🐈</h1>
  <p class="updated-at">last updated <time id="updated-at" datetime="{{ updated_at }}"></time></p>
  <script>
    const t = document.getElementById('updated-at');
    t.textContent = new Date(t.dateTime).toLocaleString(undefined, {
      dateStyle: 'medium', timeStyle: 'short'
    });
  </script>
  <h2>leaderboard</h2>
  <div id="table-container" class="table-wrap">
    <table class="results-table">
      <thead>
        <tr>
          <th class="col-user"></th>
          {% for col in columns %}
          <th class="{{ 'col-summary' if col.is_summary else '' }}">{% if col.url %}<a href="{{ col.url }}" target="_blank">{{ col.label }}</a>{% else %}{{ col.label }}{% endif %}</th>
          {% endfor %}
        </tr>
      </thead>
      <tbody>
        {% for row in rows %}
        <tr class="{{ 'row-sep' if row.row_sep else '' }}">
          <th class="col-user">{{ row.label }}</th>
          {% for cell in row.cells %}
          <td class="{{ 'col-sep' if cell.col_sep else '' }}"{% if cell.bg %} style="background-color: {{ cell.bg }}"{% endif %}>{{ cell.display }}</td>
          {% endfor %}
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <h2>per-day results</h2>
  <div id="guess-breakdown"></div>

  <script type="text/babel">
    function hammingDist(a, b) {
      const n = Math.min(a.length, b.length);
      let dist = 0;
      for (let i = 0; i < n; i++) {
        if (a[i] !== b[i]) dist++;
      }
      return dist;
    }

    function mostInSync(records) {
      let best = null, bestDist = Infinity;
      for (let i = 0; i < records.length; i++) {
        for (let j = i + 1; j < records.length; j++) {
          const d = hammingDist(records[i].guesses, records[j].guesses);
          if (d < bestDist) {
            bestDist = d;
            best = [records[i].username, records[j].username];
          }
        }
      }
      return best;
    }

    function GuessCell({ g }) {
      if (g === 1 || g === true)  return <td className="guess-hit">🐈</td>;
      if (g === 0.5)               return <td className="guess-half">🥚</td>;
      if (g === 0 || g === false)  return <td className="guess-miss">🐟</td>;
      return <td></td>;
    }

    function GuessBreakdown() {
      const [allDays, setAllDays] = React.useState([]);
      const [dayMap,  setDayMap]  = React.useState({});
      const [idx,     setIdx]     = React.useState(0);

      React.useEffect(() => {
        fetch('data.json')
          .then(r => r.json())
          .then(data => {
            const map = {};
            data.forEach(rec => {
              const guesses = typeof rec.guesses === 'string' ? JSON.parse(rec.guesses) : rec.guesses;
              if (!map[rec.day_number]) map[rec.day_number] = [];
              map[rec.day_number].push({ username: rec.username, score: rec.score, total: rec.total, guesses });
            });
            const days = Object.keys(map).map(Number).sort((a, b) => a - b);
            setDayMap(map);
            setAllDays(days);
            setIdx(days.length - 1);
          });
      }, []);

      if (allDays.length === 0) return null;

      const day       = allDays[idx];
      const records   = [...dayMap[day]].sort((a, b) => b.score - a.score);
      const numGuesses = Math.max(...records.map(r => r.guesses.length));
      const syncPair  = mostInSync(records);

      return (
        <>
          <div id="day-nav">
            <button onClick={() => setIdx(i => i - 1)} disabled={idx === 0}>←</button>
            <span id="day-label">
              <a href={`https://catfishing.net/game/${day}`} target="_blank">#{day}</a>
            </span>
            <button onClick={() => setIdx(i => i + 1)} disabled={idx === allDays.length - 1}>→</button>
          </div>
          <div className="table-wrap">
            <table className="guess-table">
              <thead>
                <tr>
                  <th className="col-user"></th>
                  {Array.from({ length: numGuesses }, (_, i) => <th key={i}>{i + 1}</th>)}
                  <th className="col-sep">Score</th>
                </tr>
              </thead>
              <tbody>
                {records.map(rec => (
                  <tr key={rec.username}>
                    <th className="col-user">{rec.username}</th>
                    {Array.from({ length: numGuesses }, (_, i) =>
                      i < rec.guesses.length
                        ? <GuessCell key={i} g={rec.guesses[i]} />
                        : <td key={i}></td>
                    )}
                    <td className="col-sep">{rec.score}/{rec.total}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          {syncPair && (
            <p className="most-in-sync">Most in sync: <strong>{syncPair[0]}</strong> and <strong>{syncPair[1]}</strong></p>
          )}
        </>
      );
    }

    ReactDOM.createRoot(document.getElementById('guess-breakdown')).render(<GuessBreakdown />);
  </script>
</body>
</html>
